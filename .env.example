# Database
DATABASE_URL="mysql://root:password@localhost:3306/arvis_shop"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Upload directory (relative to public/)
UPLOAD_DIR="uploads"

# Optional: Courier API (for tracking integration)
COURIER_API_URL=""
COURIER_API_KEY=""

# Production
NODE_ENV="production"
