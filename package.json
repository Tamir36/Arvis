{
  "name": "arvis-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:fresh",
    "dev:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$p = Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue; if ($p) { Stop-Process -Id ($p | Select-Object -ExpandProperty OwningProcess -Unique) -Force -ErrorAction SilentlyContinue }; if (Test-Path .next) { Remove-Item .next -Recurse -Force -ErrorAction SilentlyContinue }; if (Test-Path .next-dev) { Remove-Item .next-dev -Recurse -Force -ErrorAction SilentlyContinue }; if (Test-Path node_modules\\.cache) { Remove-Item node_modules\\.cache -Recurse -Force -ErrorAction SilentlyContinue }; next dev -p 3000\"",
    "dev:clean": "npm run dev:fresh",
    "build": "next build",
    "start": "next start",
    "railway:build": "npm run db:generate && npm run build",
    "railway:start": "node scripts/railway-start.mjs",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:purge-business": "node scripts/purge-business-data.mjs --force",
    "db:purge-app-data": "node scripts/purge-business-data.mjs --force",
    "db:backfill-driver-reservations": "node scripts/backfill-driver-reservations.mjs",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.2.0",
    "@hookform/resolvers": "^3.6.0",
    "@prisma/client": "^5.14.0",
    "@tanstack/react-table": "^8.17.3",
    "@tiptap/extension-link": "^2.4.0",
    "@tiptap/extension-placeholder": "^2.4.0",
    "@tiptap/extension-text-align": "^2.4.0",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lodash": "^4.18.1",
    "lucide-react": "^0.395.0",
    "multer": "^1.4.5-lts.1",
    "next": "^15.5.14",
    "next-auth": "^5.0.0-beta.19",
    "papaparse": "^5.4.1",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.52.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.7",
    "sharp": "^0.33.4",
    "tailwind-merge": "^2.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
